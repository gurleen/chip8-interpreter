---
Checks: >
  clang-diagnostic-*,
  clang-analyzer-*,
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  misc-*,
  performance-*,
  readability-*,
  -readability-magic-numbers,
  -readability-identifier-length

# Leave empty to keep tidy warnings advisory (not build-breaking).
WarningsAsErrors: ''

# Only lint project headers, not system or package headers.
HeaderFilterRegex: 'include/.*\.h$'

FormatStyle: file

CheckOptions:
  - key: readability-braces-around-statements.ShortStatementLines
    value: '0'
